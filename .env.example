# Backend
BACKEND_PORT=8080
FRONTEND_PORT=5173

# OIDC — backend (keep secret)
OIDC_ISSUER_URL=https://sso.scottylabs.org/realms/scottylabs
OIDC_CLIENT_ID=cmuinsta
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_REDIRECT_URI=http://localhost:5173/oauth/callback

# OIDC — frontend (public, bundled by Vite)
VITE_OIDC_ISSUER_URL=https://sso.scottylabs.org/realms/scottylabs
VITE_OIDC_CLIENT_ID=cmuinsta
VITE_OIDC_REDIRECT_URI=http://localhost:5173/oauth/callback

# Admin Andrew IDs (comma-separated)
ADMIN_IDS=etashjha

# Instagram
INSTAGRAM_ACCESS_TOKEN=your-token-here
