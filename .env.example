
# Database Configuration
DATABASE_URL=POSTGRES_URL

# Backend server port
BACKEND_PORT=8080
# Frontend dev server port
FRONTEND_PORT=5173

# Authentication (Keycloak OIDC via ScottyLabs SSO)
# Keycloak server URL
OIDC_ISSUER_URL=OIDC_ISSUER_URL
# OIDC Client credentials (keep secret - backend only!)
OIDC_CLIENT_ID=OIDC_CLIENT_ID
OIDC_CLIENT_SECRET=OIDC_CLIENT_SECRET
# OAuth redirect URI (where Keycloak sends users after login)
OIDC_REDIRECT_URI=OIDC_REDIRECT_URI

# Frontend needs to know where to redirect for login (public, no secret)
VITE_OIDC_ISSUER_URL=VITE_OIDC_ISSUER_URL
VITE_OIDC_CLIENT_ID=VITE_OIDC_CLIENT_ID
VITE_OIDC_REDIRECT_URI=VITE_OIDC_REDIRECT_URI

# Admin Configuration
ADMIN_IDS=etashjha

# Directory where uploaded posts are stored
# Path is relative to project backend
POSTS_STORE_DIR=../.posts_store

INSTAGRAM_KEY=INSTAGRAM_KEY
